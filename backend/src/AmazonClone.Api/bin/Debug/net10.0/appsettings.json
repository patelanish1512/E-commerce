{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=AmazonCloneDb;Username=postgres;Password=postgres",
    "RedisConnection": "localhost:6379"
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyForAmazonCloneWhichNeedsToBeLongEnough",
    "Issuer": "AmazonCloneBackend",
    "Audience": "AmazonCloneFrontend",
    "ExpiryMinutes": 60
  },
  "AWS": {
    "Profile": "default",
    "Region": "us-east-1",
    "BucketName": "amazonclone-dummy-bucket"
  }
}